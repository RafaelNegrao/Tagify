{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tagify",
  "version": "../package.json",
  "identifier": "com.etiquetas.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tagify - Impressao Termica",
        "width": 1180,
        "height": 720,
        "minWidth": 900,
        "minHeight": 560,
        "center": true,
        "decorations": false,
        "maximized": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
