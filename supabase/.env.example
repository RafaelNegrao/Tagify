# Secrets for the license Edge Functions. Set these with:
#   supabase secrets set --env-file supabase/.env
# (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected automatically in production.)

# 32-byte Ed25519 seed (hex). MUST be the SAME seed already used by the app's public key
# (tools/keygen/secret.key), so passes the server signs validate against the embedded key.
LICENSE_SIGNING_SEED=b9ef798ffa4b1115979c7312cb615dd15cbdcffa73881c2fe19ebea87967708f

# Mercado Pago access token (Credenciais de produção -> Access Token).
MP_ACCESS_TOKEN=

# Optional but recommended: secret to validate the x-signature of MP webhooks.
MP_WEBHOOK_SECRET=
